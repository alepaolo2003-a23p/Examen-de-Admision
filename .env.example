# Puerto en el que escucha el servidor Express
PORT=3000

# Cadena de conexión a MongoDB Atlas
# Reemplazar <usuario>, <password> y <cluster> por los valores reales del cluster
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/admision_2026?retryWrites=true&w=majority

# Secreto para la firma de JSON Web Tokens
JWT_SECRET=cambia_este_valor_por_un_secreto_seguro

# Entorno de ejecución
NODE_ENV=development
